# Gemini API Key for Embeddings and Primary LLM Agent (Required)
# Get a free key at https://aistudio.google.com/
GEMINI_API_KEY="your_gemini_api_key_here"

# Groq API Key for Fallback LLM Agent inference (Optional)
GROQ_API_KEY="your_groq_api_key_here"

# CricAPI Key for Live Match Polling (Required for Live Mode)
# Get a free tier key at https://cricapi.com/
CRIC_API_KEY="your_cricapi_key_here"
